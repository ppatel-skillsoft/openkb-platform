# .env.docker — environment for local Docker Compose development
#
# Copy this file to .env and fill in your LLM API key.
# Everything else is pre-configured for the Azurite emulator.
# DO NOT commit .env with real credentials.

# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_API_KEY=                        # required: your OpenAI / Anthropic / etc. key

# ── Storage (Azurite — pre-filled, do not change for local dev) ───────────────
# The API defaults to OPENKB_STORAGE_BACKEND=azure.
# docker-compose.yml sets the connection string to the azurite service automatically.
# Switching to real Azure: see .env.azure.example
AZURE_KB_CONTAINER=openkb
