# LLM API key (required) — works with any LiteLLM-supported provider
# OpenAI:    LLM_API_KEY=sk-...
# Anthropic: LLM_API_KEY=sk-ant-...
# Gemini:    LLM_API_KEY=AIza...
# DeepSeek:  LLM_API_KEY=sk-...
LLM_API_KEY=your-key-here

# ---------------------------------------------------------------------------
# Phase 0 Postgres connection (required for openkb.db and alembic migrations)
# ---------------------------------------------------------------------------
# Local dev (Docker Compose): use the defaults below — no edits needed.
# Production (Azure Database for PostgreSQL Flexible Server):
#   DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:5432/<dbname>?ssl=require
#
# The DATABASE_URL is the only variable required by openkb.db at runtime.
# The POSTGRES_* variables are only consumed by the postgres Docker service.
DATABASE_URL=postgresql+asyncpg://openkb:openkb@localhost:5433/openkb?sslmode=disable
POSTGRES_USER=openkb
POSTGRES_PASSWORD=openkb
POSTGRES_DB=openkb
